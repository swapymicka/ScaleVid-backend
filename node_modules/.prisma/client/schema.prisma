// Schéma de base de données ScaleVid.
// SQLite par défaut (zéro config en local) — passe à "postgresql" pour la prod
// (voir DATABASE_URL dans .env).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  plan         String   @default("creator") // "creator" | "agency"
  period       String   @default("monthly") // "monthly" | "annual"
  accountSlots Int      @default(1) // nombre de comptes payés dans l'abonnement
  createdAt    DateTime @default(now())

  socialAccounts SocialAccount[]
  videos         Video[]
}

// Un compte YouTube ou TikTok connecté par l'utilisateur.
model SocialAccount {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  provider       String // "youtube" | "tiktok"
  externalId     String // identifiant du compte chez la plateforme
  handle         String // nom affiché (@handle)
  accessToken    String // chiffré (voir tokenCrypto.js) avant stockage
  refreshToken   String? // chiffré
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())

  scheduledPosts ScheduledPost[]

  @@unique([provider, externalId])
}

// Une vidéo source importée par l'utilisateur.
model Video {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  sourcePath  String // chemin/clé de stockage du fichier original
  durationSec Float?
  status      String   @default("uploaded") // uploaded -> transcribing -> analyzing -> cutting -> done -> failed
  error       String?
  createdAt   DateTime @default(now())

  clips Clip[]
}

// Un clip généré par le pipeline IA à partir d'une vidéo source.
model Clip {
  id         String   @id @default(uuid())
  videoId    String?
  video      Video?   @relation(fields: [videoId], references: [id])
  startSec   Float
  endSec     Float
  title      String
  caption    String
  viralScore Int
  reasoning  String?
  outputPath String? // chemin du fichier découpé une fois prêt
  status     String   @default("pending") // pending -> rendering -> ready -> failed
  createdAt  DateTime @default(now())

  scheduledPosts ScheduledPost[]
}

// Une publication programmée d'un clip vers un compte connecté.
model ScheduledPost {
  id              String        @id @default(uuid())
  clipId          String
  clip            Clip          @relation(fields: [clipId], references: [id])
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])
  scheduledAt     DateTime
  status          String        @default("scheduled") // scheduled -> publishing -> published -> failed
  platformPostId  String?
  error           String?
  createdAt       DateTime      @default(now())
}
