{
  "name": "scalevid-backend",
  "version": "0.1.0",
  "description": "Backend réel pour ScaleVid : OAuth YouTube/TikTok, pipeline IA (transcription + Claude) et découpage vidéo ffmpeg.",
  "type": "commonjs",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "npx prisma db push --accept-data-loss && node src/index.js",
    "worker": "node src/worker.js",
    "worker:dev": "nodemon src/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate",
    "render-build": "npm install && npx prisma migrate deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@prisma/client": "^5.20.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "openai": "^4.63.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.20.0"
  }
}
