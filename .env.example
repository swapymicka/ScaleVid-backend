# ============================================================
# ScaleVid backend — variables d'environnement
# Copie ce fichier en ".env" et remplis les valeurs.
# Ne commite JAMAIS le fichier ".env" réel dans git.
# ============================================================

# --- Serveur ---
PORT=4000
APP_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-moi-en-une-longue-chaine-aleatoire
TOKEN_ENCRYPTION_KEY=change-moi-32-caracteres-minimum

# --- Base de données (SQLite par défaut, zéro config) ---
# Pour passer en production, remplace par une URL Postgres :
# DATABASE_URL="postgresql://user:password@host:5432/scalevid"
DATABASE_URL="file:./dev.db"

# --- Redis (file de jobs BullMQ) ---
# Pour tester sans Redis, mets USE_QUEUE=false : le traitement vidéo
# se fait alors directement dans la requête HTTP (pratique en local,
# déconseillé en production car ça bloque le serveur).
USE_QUEUE=false
REDIS_URL=redis://localhost:6379

# --- Google / YouTube ---
# 1. Va sur https://console.cloud.google.com/
# 2. Crée un projet, active "YouTube Data API v3"
# 3. Configure l'écran de consentement OAuth (mode "Test" pour commencer)
# 4. Crée un identifiant OAuth 2.0 "Application Web"
# 5. Ajoute cette URI de redirection autorisée :
#    http://localhost:4000/auth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/youtube/callback

# --- TikTok ---
# 1. Va sur https://developers.tiktok.com/
# 2. Crée une app, demande l'accès à "Login Kit" et "Content Posting API"
#    (la Content Posting API en mode "Direct Post" nécessite une validation
#    de l'app par TikTok avant de pouvoir publier pour de vrais utilisateurs)
# 3. Ajoute cette URI de redirection :
#    http://localhost:4000/auth/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/auth/tiktok/callback

# --- IA ---
# Clé Anthropic : sélection des meilleurs moments, titres, sous-titres.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Clé OpenAI : utilisée uniquement pour la transcription audio (Whisper).
# Tu peux remplacer ce service par un autre fournisseur (AssemblyAI, Deepgram,
# whisper.cpp en local) — voir src/services/transcriptionService.js
OPENAI_API_KEY=

# --- Stockage des vidéos ---
# En local : stockage sur disque dans ./storage
# En production : remplace par un bucket S3 / Cloudflare R2 (voir README)
STORAGE_DIR=./storage

# --- Email de bienvenue (envoyé à l'inscription via Gmail) ---
# 1. Active la validation en 2 étapes sur le compte Gmail : https://myaccount.google.com/security
# 2. Crée un "mot de passe d'application" : https://myaccount.google.com/apppasswords
#    (choisis "Autre", nomme-le "ScaleVid", copie le mot de passe à 16 caractères généré)
# 3. GMAIL_USER = l'adresse Gmail complète, GMAIL_APP_PASSWORD = ce mot de passe généré
#    (PAS le mot de passe normal du compte Gmail — ça ne fonctionnera pas)
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=ScaleVid
